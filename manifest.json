{
  "manifest_version": 1,
  "type": "WebApp",
  "meta": {
    "name": "LaneUp",
    "version": "0.1.0",
    "minimum-overwolf-version": "0.220.0",
    "author": "Yushaw",
    "icon": "icons/icon.png",
    "icon_gray": "icons/icon_gray.png",
    "description": "Beginner-focused League of Legends companion. Role guides, champ select help, and real-time death review."
  },

  "permissions": ["GameEvents", "Hotkeys", "GameInfo"],

  "windows": {
    "background": {
      "file": "background.html",
      "transparent": true,
      "show_in_taskbar": false,
      "size": { "width": 0, "height": 0 }
    },

    "desktop": {
      "file": "windows/desktop/desktop.html",
      "transparent": false,
      "resizable": true,
      "show_in_taskbar": true,
      "size":     { "width": 420, "height": 700 },
      "min_size": { "width": 380, "height": 600 },
      "keep_window_location": true
    },

    "in_game": {
      "file": "windows/in-game/in-game.html",
      "transparent": true,
      "resizable": false,
      "show_in_taskbar": false,
      "size": { "width": 340, "height": 580 },
      "clickthrough": false,
      "keep_window_location": true
    }
  },

  "hotkeys": {
    "toggle_app": {
      "title": "Toggle LaneUp",
      "action-type": "custom",
      "default": "Ctrl+Shift+L"
    },
    "show_guide": {
      "title": "Show/hide in-game guide",
      "action-type": "custom",
      "default": "Ctrl+Shift+G"
    }
  },

  "launch_events": [
    {
      "event": "GameLaunch",
      "event_data": {
        "game_ids": [5426]
      },
      "start_minimized": true
    }
  ],

  "data": {
    "start_window": "background",
    "game_targeting": {
      "type": "dedicated",
      "game_ids": [5426]
    }
  }
}
